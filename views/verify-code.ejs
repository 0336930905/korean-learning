<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác nhận mã - Korea_DB</title>
    <%- include('partials/Header') %>
    <link rel="stylesheet" href="/style/style.css">
    <link rel="stylesheet" href="/style/login.css">
    <style>
        .form-container {
            max-width: 450px;
            margin: 40px auto;
            padding: 30px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        .verification-title {
            color: #2563eb;
            margin-bottom: 25px;
            text-align: center;
            font-weight: 600;
        }
        .verification-info {
            text-align: center;
            color: #4b5563;
            margin-bottom: 20px;
        }
        .verification-email {
            color: #2563eb;
            font-weight: 500;
            word-break: break-all;
        }
        .form-group {
            margin-bottom: 25px;
        }
        .verification-code {
            letter-spacing: 8px;
            font-size: 24px;
            text-align: center;
        }
        .btn-verify {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            background: #2563eb;
            color: white;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        .btn-verify:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #6b7280;
            text-decoration: none;
        }
        .back-link:hover {
            color: #2563eb;
        }
        .modal-content {
            border-radius: 15px;
        }
        .modal-header {
            background: #f8fafc;
            border-radius: 15px 15px 0 0;
        }
        .modal-title {
            color: #2563eb;
            font-weight: 600;
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="container">
        <div class="form-container">
            <h2 class="verification-title">
                <%= !email ? 'Khôi phục mật khẩu' : 'Xác nhận mã' %>
            </h2>

            <% if (error) { %>
                
            <% } %>
            
            <% if (message) { %>
                
            <% } %>

            <% if (!email) { %>
                <!-- Email Form -->
                <form action="/forgot-password" method="POST">
                    <div class="form-group">
                        <label class="font-medium mb-2">Email của bạn</label>
                        <input type="email" 
                               class="form-control" 
                               name="email" 
                               required 
                               placeholder="Nhập email đã đăng ký">
                    </div>
                    <button type="submit" class="btn-verify">
                        <i class="fas fa-paper-plane mr-2"></i>
                        Gửi mã xác nhận
                    </button>
                </form>
            <% } else { %>
                <!-- Verification Code Form -->
                <div class="verification-info">
                    <i class="fas fa-envelope mb-3" style="font-size: 2rem; color: #2563eb;"></i>
                    <p>Chúng tôi đã gửi mã xác nhận đến:</p>
                    <div class="verification-email"><%= email %></div>
                </div>
                <form action="/verify-code" method="POST">
                    <input type="hidden" name="email" value="<%= email %>">
                    <div class="form-group">
                        <input type="text" 
                               class="form-control verification-code" 
                               name="code" 
                               required 
                               maxlength="6" 
                               pattern="[0-9]{6}"
                               autocomplete="off"
                               placeholder="------">
                    </div>
                    <button type="submit" class="btn-verify">
                        <i class="fas fa-key mr-2"></i>
                        Xác nhận mã
                    </button>
                </form>
            <% } %>

            <a href="/login" class="back-link">
                <i class="fas fa-arrow-left mr-2"></i>
                Quay lại đăng nhập
            </a>
        </div>
    </div>

    <%- include('partials/Footer') %>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto focus and format verification code input
        const codeInput = document.querySelector('input[name="code"]');
        if (codeInput) {
            codeInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });
            codeInput.focus();
        }

        // Form submission handling
        document.querySelector('form[action="/verify-code"]')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;

            try {
                const email = form.querySelector('input[name="email"]').value;
                const code = form.querySelector('input[name="code"]').value;

                const response = await fetch('/verify-code', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email, code })
                });

                const data = await response.json();

                if (data.success) {
                    // Redirect to reset password page instead of showing modal
                    window.location.href = `/reset-password?email=${email}&code=${code}`;
                } else {
                    throw new Error(data.error || 'Mã xác nhận không hợp lệ');
                }
            } catch (error) {
                console.error('Error:', error);
                alert(error.message || 'Có lỗi xảy ra. Vui lòng thử lại.');
            } finally {
                submitBtn.disabled = false;
            }
        });
    </script>
</body>
</html>