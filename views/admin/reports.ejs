<%- include('../partials/header') %>
<h2 class="mb-4"><i class="fas fa-chart-bar me-2 text-primary"></i>Reports</h2>
<div class="row g-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">Users by Role</div>
      <div class="card-body">
        <% usersByRole.forEach(r => { %>
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span class="badge bg-<%= r._id === 'admin' ? 'danger' : r._id === 'teacher' ? 'warning' : 'info' %> fs-6"><%= r._id %></span>
          <strong><%= r.count %> users</strong>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">Academic Overview</div>
      <div class="card-body">
        <div class="d-flex justify-content-between mb-2">
          <span>Total Courses</span><strong><%= courseCount %></strong>
        </div>
        <div class="d-flex justify-content-between">
          <span>Total Classes</span><strong><%= classCount %></strong>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
