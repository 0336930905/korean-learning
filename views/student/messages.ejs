<%- include('../partials/header') %>
<h2 class="mb-4"><i class="fas fa-envelope me-2 text-primary"></i>Messages</h2>
<div class="row">
  <div class="col-md-3">
    <div class="card">
      <div class="card-header">Teachers</div>
      <div class="list-group list-group-flush" id="contactList">
        <% teachers.forEach(t => { %>
        <a href="#" class="list-group-item list-group-item-action contact-item" data-userid="<%= t._id %>" data-username="<%= t.name %>">
          <i class="fas fa-chalkboard-teacher me-2"></i><%= t.name %>
        </a>
        <% }) %>
        <% if (teachers.length === 0) { %><div class="list-group-item text-muted">No teachers available</div><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-9">
    <div class="card">
      <div class="card-header" id="chatHeader">Select a teacher to start chatting</div>
      <div class="card-body" style="height:400px;overflow-y:auto;" id="messageArea">
        <% messages.forEach(m => { %>
        <div class="mb-2 text-<%= m.sender._id.toString() === user._id.toString() ? 'end' : 'start' %>">
          <span class="badge bg-<%= m.sender._id.toString() === user._id.toString() ? 'primary' : 'secondary' %> p-2">
            <strong><%= m.sender.name %>:</strong> <%= m.content %>
          </span>
          <div class="small text-muted"><%= new Date(m.createdAt).toLocaleString() %></div>
        </div>
        <% }) %>
      </div>
      <div class="card-footer">
        <div class="input-group">
          <input type="text" id="messageInput" class="form-control" placeholder="Type a message..." disabled>
          <button class="btn btn-primary" id="sendBtn" disabled><i class="fas fa-paper-plane"></i></button>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
const currentUserId = '<%= user._id %>';
const socket = io();
socket.emit('join', currentUserId);
let selectedUserId = null;

document.querySelectorAll('.contact-item').forEach(item => {
  item.addEventListener('click', function(e) {
    e.preventDefault();
    selectedUserId = this.dataset.userid;
    document.getElementById('chatHeader').textContent = 'Chat with ' + this.dataset.username;
    document.getElementById('messageInput').disabled = false;
    document.getElementById('sendBtn').disabled = false;
    document.querySelectorAll('.contact-item').forEach(i => i.classList.remove('active'));
    this.classList.add('active');
  });
});

document.getElementById('sendBtn').addEventListener('click', sendMessage);
document.getElementById('messageInput').addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });

function sendMessage() {
  const content = document.getElementById('messageInput').value.trim();
  if (!content || !selectedUserId) return;
  socket.emit('sendMessage', { senderId: currentUserId, receiverId: selectedUserId, content });
  document.getElementById('messageInput').value = '';
}

socket.on('messageSent', data => {
  const area = document.getElementById('messageArea');
  area.innerHTML += `<div class="mb-2 text-end"><span class="badge bg-primary p-2"><strong>You:</strong> ${data.content}</span><div class="small text-muted">${new Date(data.createdAt).toLocaleString()}</div></div>`;
  area.scrollTop = area.scrollHeight;
});

socket.on('receiveMessage', data => {
  const area = document.getElementById('messageArea');
  area.innerHTML += `<div class="mb-2 text-start"><span class="badge bg-secondary p-2"><strong>${data.sender.name}:</strong> ${data.content}</span><div class="small text-muted">${new Date(data.createdAt).toLocaleString()}</div></div>`;
  area.scrollTop = area.scrollHeight;
});
</script>
<%- include('../partials/footer') %>
