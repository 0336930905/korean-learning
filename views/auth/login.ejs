<%- include('../partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm border-0 mt-3">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          <i class="fas fa-book-open fa-3x text-primary mb-2"></i>
          <h3 class="fw-bold">Korean Learning Center</h3>
          <p class="text-muted">Sign in to your account</p>
        </div>
        <form action="/auth/login" method="POST">
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
          </div>
          <button type="submit" class="btn btn-primary w-100 mb-3">
            <i class="fas fa-sign-in-alt me-2"></i>Login
          </button>
        </form>
        <div class="divider text-center my-3">
          <span class="bg-white px-2 text-muted">or</span>
          <hr class="mt-n3">
        </div>
        <a href="/auth/google" class="btn btn-outline-danger w-100">
          <i class="fab fa-google me-2"></i>Continue with Google
        </a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
