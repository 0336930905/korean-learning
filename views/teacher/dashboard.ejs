<%- include('../partials/header') %>
<h2 class="mb-4"><i class="fas fa-chalkboard-teacher me-2 text-primary"></i>Teacher Dashboard</h2>
<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card bg-primary text-white">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div><h6>My Classes</h6><h2><%= stats.classes %></h2></div>
        <i class="fas fa-chalkboard fa-2x opacity-75"></i>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card bg-warning text-white">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div><h6>Assignments</h6><h2><%= stats.assignments %></h2></div>
        <i class="fas fa-tasks fa-2x opacity-75"></i>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card bg-info text-white">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div><h6>Unread Messages</h6><h2><%= stats.unreadMessages %></h2></div>
        <i class="fas fa-envelope fa-2x opacity-75"></i>
      </div>
    </div>
  </div>
</div>
<div class="card">
  <div class="card-header"><i class="fas fa-chalkboard me-2"></i>My Classes</div>
  <div class="card-body">
    <div class="row g-3">
      <% myClasses.forEach(cls => { %>
      <div class="col-md-4">
        <div class="card border">
          <div class="card-body">
            <h6 class="card-title"><%= cls.name %></h6>
            <p class="card-text text-muted small"><%= cls.course ? cls.course.name : '' %></p>
            <p class="small"><i class="fas fa-calendar me-1"></i><%= cls.schedule || 'No schedule' %></p>
          </div>
        </div>
      </div>
      <% }) %>
      <% if (myClasses.length === 0) { %>
      <div class="col-12 text-center text-muted"><p>No classes assigned</p></div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
